/dts-v1/;

/ {
	#address-cells = <0x01>;
	#size-cells = <0x01>;
	model = "DAVOLINK GAPD-7200";
	compatible = "Davolink,gapd-7200", "qcom,ipq4019";

	chosen {
		bootargs = "ubi.mtd=ubi rootfstype=squashfs";
	};

	aliases {
		spi0 = "/soc/spi@78b5000";
		ethernet0 = "/soc/ethernet@c080000";
	};

	memory {
		device_type = "memory";
		reg = <0x80000000 0x10000000>;
	};

	soc {
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		ranges;
		compatible = "simple-bus";

		pinctrl@1000000 {
			compatible = "qcom,ipq4019-pinctrl";
			reg = <0x1000000 0x300000>;
			gpio-controller;
			gpio-ranges = <&tlmm 0 0 100>;
			#gpio-cells = <0x02>;
			interrupt-controller;
			#interrupt-cells = <0x02>;

			tlmm: serial_pinmux {
				mux {
					pins = "gpio60", "gpio61";
					function = "blsp_uart0";
					bias-disable;
				};
			};

			spi_0_pinmux {
				mux {
					function = "blsp_spi0";
					pins = "gpio55", "gpio56", "gpio57";
					drive-strength = <0x0c>;
					bias-disable;
				};

				mux_cs {
					function = "gpio";
					pins = "gpio54", "gpio59";
					drive-strength = <0x02>;
					bias-disable;
					output-high;
				};
			};
		};

		spi@78b5000 {
			compatible = "qcom,spi-qup-v2.2.1";
			reg = <0x78b5000 0x600>;
			#address-cells = <0x01>;
			#size-cells = <0x00>;
			status = "okay";

			flash@0 {
				compatible = "jedec,spi-nor";
				reg = <0x00>;
				spi-max-frequency = <24000000>;
				#address-cells = <0x01>;
				#size-cells = <0x01>;

				partitions {
					compatible = "fixed-partitions";
					#address-cells = <0x01>;
					#size-cells = <0x01>;

					partition@0 {
						label = "SBL1";
						reg = <0x00 0x40000>;
						read-only;
					};

					partition@40000 {
						label = "MIBIB";
						reg = <0x40000 0x20000>;
						read-only;
					};

					partition@60000 {
						label = "QSEE";
						reg = <0x60000 0x60000>;
						read-only;
					};

					partition@c0000 {
						label = "CDT";
						reg = <0xc0000 0x10000>;
						read-only;
					};

					partition@d0000 {
						label = "DDRPARAMS";
						reg = <0xd0000 0x10000>;
						read-only;
					};

					partition@e0000 {
						label = "APPSBLENV";
						reg = <0xe0000 0x10000>;
					};

					partition@f0000 {
						label = "APPSBL";
						reg = <0xf0000 0x80000>;
						read-only;
					};

					art: partition@170000 {
						label = "ART";
						reg = <0x170000 0x10000>;
						read-only;

						precal_f0: precal@1000 {
							reg = <0x1000 0x2f20>;
						};

						precal_f1: precal@5000 {
							reg = <0x5000 0x2f20>;
						};
					};

					partition@180000 {
						label = "BOOTCONFIG";
						reg = <0x180000 0x40000>;
						read-only;
					};

					config: partition@1c0000 {
						label = "RESV";
						reg = <0x1c0000 0x240000>;
						read-only;

						macaddr_auth: macaddr@0 {
							reg = <0x00 0x06>;
						};
					};
				};
			};

			spi_nand@1 {
				compatible = "spi-nand";
				reg = <0x01>;
				spi-max-frequency = <30000000>;

				partitions {
					compatible = "fixed-partitions";
					#address-cells = <0x01>;
					#size-cells = <0x01>;

					partition@0 {
						label = "ubi";
						reg = <0x00 0x8000000>; /* مساحة الـ NAND بالكامل للسوفت وير */
					};
				};
			};
		};

		ethernet@c080000 {
			compatible = "qcom,ipq4019-ess-edma";
			reg = <0xc080000 0x8000>;
			status = "okay";
		};
	};
};
